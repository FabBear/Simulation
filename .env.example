# FAB_BEAR — copy to FAB_BEAR/.env and edit

# PostgreSQL (docker compose db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# If 5432 is in use (e.g. Simulation stack), use 5433 and set the same in docker-compose ports.

# Optional full URL (overrides POSTGRES_* composition)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Simulation CSV output (path relative to simulation/ when running from there)
# SIM_CSV_DIR=./sim_csv_out
# SIM_END_MINUTES=200000
# KPI_INSTANT_PERIOD_MIN=60

# Optional agent debug logs (leave unset to disable)
# DEBUG_LOG_PATH=
# AGENT_DEBUG_LOG_PATH=
