# FAB_BEAR — copy to FAB_BEAR/.env and edit

# PostgreSQL (docker compose db service)
POSTGRES_USER=fabbear_user
POSTGRES_PASSWORD=fabbear_pw
POSTGRES_DB=fabbear
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Platform tables namespace (backend may use public separately)
POSTGRES_SCHEMA=simulation

# Optional full URL (overrides POSTGRES_* composition)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
